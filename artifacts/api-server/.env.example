PORT=3000
NODE_ENV=production

# Database — PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/etherbound
# Remote: postgresql://etherbound:password@DB_SERVER_IP:5432/etherbound
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/etherbound

# Database pool size per process (lower when running multiple PM2 instances)
DB_POOL_MAX=10

# Redis — enables cluster mode, shared cache, Socket.IO multi-process adapter
# Leave empty to run single-process with in-memory cache
# Format: redis://[:password@]host:port
REDIS_URL=

# Rate limits (increase for load testing)
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=60
FIGHT_RATE_LIMIT=10
